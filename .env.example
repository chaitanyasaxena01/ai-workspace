# ---------------------------------------------------------------------------
# AI Agent Playground — environment surface
# Copy to `.env.local` (web) and `.dev.vars` (api) as needed.
# ---------------------------------------------------------------------------

# --- Auth.js (apps/web) ---------------------------------------------------
# Secret used to sign/verify the session JWT. Generate with:
#   npx auth secret
AUTH_SECRET=""
# Public base URL of the app (used by Auth.js callbacks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Public URL of the deployed Cloudflare Worker (runtime that runs agents)
NEXT_PUBLIC_WORKER_URL="http://localhost:8787"

# --- Provider API keys (used by the Worker runtime) ----------------------
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
# Cloudflare Workers AI REST path (provider prefix `cloudflare:`). Optional if
# you only use the Worker AI binding (`cloudflare-workers-ai:`).
CLOUDFLARE_API_KEY=""
CLOUDFLARE_ACCOUNT_ID=""
# Optional: only if you created an AI Gateway in the Cloudflare dashboard.
# Do NOT put your account id here — it must be the gateway name/id.
# CLOUDFLARE_AI_GATEWAY_ID=""

# --- Agent runtime defaults (apps/api) -----------------------------------
# Default model id used when a request does not specify one.
# Examples:
#   openai:gpt-4o-mini
#   cloudflare-workers-ai:@cf/moonshotai/kimi-k2.7-code
#   cloudflare-workers-ai:@cf/meta/llama-3.3-70b-instruct-fp8-fast
DEFAULT_MODEL="cloudflare-workers-ai:@cf/moonshotai/kimi-k2.7-code"

# --- Cloudflare KV binding name (apps/api) -------------------------------
# The Worker binds a KV namespace used for notes/agent memory.
# (Configured in wrangler.toml as `AGENT_KV`.)
