# ---------------------------------------------------------------------------
# AI Agent Playground — environment surface
# Copy to `.env.local` (web) and `.dev.vars` (api) as needed.
# ---------------------------------------------------------------------------

# --- Auth.js (apps/web) ---------------------------------------------------
# Secret used to sign/verify the session JWT. Generate with:
#   npx auth secret
AUTH_SECRET=""
# Public base URL of the app (used by Auth.js callbacks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Public URL of the deployed Cloudflare Worker (runtime that runs agents)
NEXT_PUBLIC_WORKER_URL="http://localhost:8787"

# --- Provider API keys (used by the Worker runtime) ----------------------
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
# Cloudflare Workers AI / AI Gateway (OpenAI-compatible). Optional.
CLOUDFLARE_API_KEY=""
CLOUDFLARE_ACCOUNT_ID=""

# --- Agent runtime defaults (apps/api) -----------------------------------
# Default model id used when a request does not specify one.
DEFAULT_MODEL="openai:gpt-4o-mini"

# --- Cloudflare KV binding name (apps/api) -------------------------------
# The Worker binds a KV namespace used for notes/agent memory.
# (Configured in wrangler.toml as `AGENT_KV`.)
